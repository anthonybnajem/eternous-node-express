{
  "name": "nodejs-backend-boilerplate",
  "version": "1.0.0",
  "description": "Professional, universal, production-ready Node backend boilerplate",
  "main": "dist/src/index",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "lint": "eslint src tests scripts commitlint.config.ts jest.config.ts migrate-mongo-config.ts --ext .ts --fix",
    "format": "prettier --write .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "seed": "tsx scripts/seed.ts",
    "test:imports": "tsx scripts/test-imports.ts",
    "test:log-report": "tsx scripts/test-log-report.ts",
    "test:email-report": "tsx scripts/test-email-report.ts",
    "test:scheduler": "tsx scripts/test-scheduler.ts",
    "migrate:up": "tsx ./node_modules/migrate-mongo/bin/migrate-mongo -f migrate-mongo-config.ts up",
    "migrate:down": "tsx ./node_modules/migrate-mongo/bin/migrate-mongo -f migrate-mongo-config.ts down",
    "migrate:create": "tsx ./node_modules/migrate-mongo/bin/migrate-mongo -f migrate-mongo-config.ts create",
    "prepare": "husky install",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "node",
    "express",
    "mongoose",
    "rest-api",
    "backend",
    "template",
    "boilerplate",
    "production-ready"
  ],
  "author": "Sahinur Islam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devSahinur/nodejs-backend-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/devSahinur/nodejs-backend-boilerplate/issues"
  },
  "homepage": "https://github.com/devSahinur/nodejs-backend-boilerplate#readme",
  "dependencies": {
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "he": "^1.2.0",
    "heic-convert": "^2.1.0",
    "helmet": "^7.1.0",
    "http-status": "^1.7.3",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "migrate-mongo": "^11.0.0",
    "moment": "^2.30.1",
    "mongoose": "^8.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prom-client": "^15.1.0",
    "stripe": "^14.19.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.0",
    "@commitlint/config-conventional": "^18.6.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@types/validator": "^13.15.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.6.3",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.4",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
